<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Cinéma – Réservation | Films</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>

  <body class="bg-light">
    <!-- NAVBAR -->
    <%- include("partials/navbar") %>

    <!-- CONTENU -->
    <main class="container py-5">
      <h1 class="mb-4 fw-bold">Films à l'affiche</h1>

      <div class="row g-4 mb-4">
        <% if (!movies || movies.length === 0) { %>
          <div class="col-12">
            <div class="alert alert-info">
              Aucun film disponible pour le moment.
            </div>
          </div>
        <% } else { %>
          <% movies.forEach((movie) => { %>
            <div class="col-md-4">
              <div class="card h-100 shadow-sm">
                <% if (movie.poster_url) { %>
                  <img
                    src="<%= movie.poster_url %>"
                    class="card-img-top"
                    alt="Affiche de <%= movie.title %>"
                  />
                <% } %>

                <div class="card-body d-flex flex-column">
                  <h5 class="card-title"><%= movie.title %></h5>

                  <p class="card-text flex-grow-1">
                    <%= movie.description || "Aucune description disponible." %>
                  </p>

                  <p class="card-text small text-muted mb-3">
                    Durée :
                    <%= movie.duration_minutes || "N/A" %> min<br />
                    Classification :
                    <%= movie.rating || "N/A" %>
                  </p>

                  <a
                    href="/films-ejs/<%= movie.id %>"
                    class="btn btn-primary mt-auto"
                  >
                    Voir les détails
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- PAGINATION -->
      <% if (typeof totalPages !== "undefined" && totalPages > 1) { %>
        <nav aria-label="Pagination des films">
          <ul class="pagination justify-content-center">
            <!-- Précédent -->
            <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
              <a
                class="page-link"
                href="/films-ejs?page=<%= page - 1 %>"
                tabindex="-1"
              >
                Précédent
              </a>
            </li>

            <!-- Numéros de pages -->
            <% for (let p = 1; p <= totalPages; p++) { %>
              <li class="page-item <%= p === page ? 'active' : '' %>">
                <a class="page-link" href="/films-ejs?page=<%= p %>">
                  <%= p %>
                </a>
              </li>
            <% } %>

            <!-- Suivant -->
            <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
              <a
                class="page-link"
                href="/films-ejs?page=<%= page + 1 %>"
              >
                Suivant
              </a>
            </li>
          </ul>
        </nav>
      <% } %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html> 
