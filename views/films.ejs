      <!-- PAGINATION -->
      <% if (typeof totalPages !== "undefined" && totalPages > 1) { %>
      <nav aria-label="Pagination films" class="mt-4">
        <ul class="pagination">
          <% if (page > 1) { %>
            <li class="page-item">
              <a class="page-link" href="/films-ejs?page=<%= page - 1 %>">
                Précédent
              </a>
            </li>
          <% } %>

          <% for (let p = 1; p <= totalPages; p++) { %>
            <li class="page-item <%= p === page ? 'active' : '' %>">
              <a class="page-link" href="/films-ejs?page=<%= p %>">
                <%= p %>
              </a>
            </li>
          <% } %>

          <% if (page < totalPages) { %>
            <li class="page-item">
              <a class="page-link" href="/films-ejs?page=<%= page + 1 %>">
                Suivant
              </a>
            </li>
          <% } %>
        </ul>
      </nav>
      <% } %>
