<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Cinéma – Réservation | Films</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>

  <body class="bg-light">
    <!-- NAVBAR -->
    <%- include("partials/navbar") %>

    <!-- CONTENU -->
    <main class="container py-5">
      <header class="mb-4 d-flex justify-content-between align-items-center">
        <h1 class="fw-bold mb-0">Films à l'affiche</h1>
        <p class="mb-0 text-muted small">
          Explorez les films disponibles et réservez vos séances.
        </p>
      </header>

      <div class="row g-4 mb-4">
        <% if (!movies || movies.length === 0) { %>
          <div class="col-12">
            <div class="alert alert-info mb-0">
              Aucun film disponible pour le moment.
            </div>
          </div>
        <% } else { %>
          <% movies.forEach(function (movie) { %>
            <div class="col-md-4">
              <div class="card h-100 shadow-sm">
                <% if (movie.poster_url) { %>
                  <img
                    src="<%= movie.poster_url %>"
                    class="card-img-top"
                    alt="Affiche de <%= movie.title %>"
                    loading="lazy"
                  />
                <% } %>

                <div class="card-body d-flex flex-column">
                  <h5 class="card-title mb-2"><%= movie.title %></h5>

                  <p class="card-text text-muted small mb-2">
                    Durée :
                    <%= movie.duration_minutes || "N/A" %> min<br />
                    Classification :
                    <%= movie.rating || "N/A" %>
                  </p>

                  <p class="card-text flex-grow-1">
                    <% if (movie.description) { %>
                      <%= movie.description.length > 200
                            ? movie.description.slice(0, 200) + "…"
                            : movie.description %>
                    <% } else { %>
                      <span class="text-muted">
                        Aucune description disponible.
                      </span>
                    <% } %>
                  </p>

                  <div class="d-flex flex-wrap gap-2 mt-3">
                    <a
                      href="/films-ejs/<%= movie.id %>"
                      class="btn btn-outline-primary btn-sm"
                    >
                      Détails
                    </a>
                    <a
                      href="/films-ejs/<%= movie.id %>/showtimes"
                      class="btn btn-primary btn-sm"
                    >
                      Voir les séances
                    </a>

                    <!-- Bouton admin : visible seulement pour ino1 (géré par JS via .js-admin-only) -->
                    <a
                      href="/admin/movies/<%= movie.id %>/edit"
                      class="btn btn-outline-secondary btn-sm js-admin-only d-none"
                    >
                      Modifier
                    </a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- PAGINATION -->
      <% if (typeof totalPages !== "undefined" && totalPages > 1) { %>
        <nav aria-label="Pagination des films">
          <ul class="pagination justify-content-center">
            <!-- Précédent -->
            <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
              <a
                class="page-link"
                href="/films-ejs?page=<%= page - 1 %>"
                tabindex="<%= page <= 1 ? '-1' : '0' %>"
              >
                Précédent
              </a>
            </li>

            <!-- Numéros de pages -->
            <% for (let p = 1; p <= totalPages; p++) { %>
              <li class="page-item <%= p === page ? 'active' : '' %>">
                <a class="page-link" href="/films-ejs?page=<%= p %>">
                  <%= p %>
                </a>
              </li>
            <% } %>

            <!-- Suivant -->
            <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
              <a
                class="page-link"
                href="/films-ejs?page=<%= page + 1 %>"
                tabindex="<%= page >= totalPages ? '-1' : '0' %>"
              >
                Suivant
              </a>
            </li>
          </ul>
        </nav>
      <% } %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>