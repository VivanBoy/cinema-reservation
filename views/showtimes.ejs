<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Cinéma – Séances</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <%- include("partials/navbar") %>

    <main class="container py-5">
      <header class="mb-4">
        <h1 class="fw-bold mb-1">
          Séances pour <%= movie ? movie.title : "film inconnu" %>
        </h1>
        <% if (movie && movie.description) { %>
          <p class="text-muted mb-0">
            <%= movie.description.length > 180
                  ? movie.description.slice(0, 180) + "…"
                  : movie.description %>
          </p>
        <% } %>
      </header>

      <% if (!movie) { %>
        <div class="alert alert-danger">
          Le film demandé n'existe pas.
        </div>
      <% } else if (!showtimes || showtimes.length === 0) { %>
        <div class="alert alert-info">
          Aucune séance programmée pour ce film.
        </div>
      <% } else { %>
        <div class="row g-4">
          <% showtimes.forEach(function (st) { 
               const startTime = st.start_time
                 ? new Date(st.start_time)
                 : null;
          %>
            <div class="col-md-6 col-lg-4">
              <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                  <h5 class="card-title mb-2">Séance</h5>

                  <p class="card-text flex-grow-1 mb-3">
                    <strong>Date &amp; heure :</strong><br />
                    <% if (startTime) { %>
                      <%= startTime.toLocaleString("fr-CA", {
                            weekday: "short",
                            year: "numeric",
                            month: "short",
                            day: "2-digit",
                            hour: "2-digit",
                            minute: "2-digit",
                          }) %>
                    <% } else { %>
                      N/A
                    <% } %>
                    <br />
                    <strong>Salle :</strong>
                    <%= st.Room ? st.Room.name : "N/A" %><br />
                    <strong>Prix :</strong>
                    <% if (st.price !== null && st.price !== undefined) { %>
                      <%= Number(st.price).toFixed(2) %> $
                    <% } else { %>
                      N/A
                    <% } %>
                  </p>

                  <!-- Bouton Réserver -->
                  <button
                    type="button"
                    class="btn btn-success mt-auto"
                    onclick="reserveShowtime(<%= st.id %>, <%= st.price || 0 %>)"
                  >
                    Réserver
                  </button>

                  <!-- Bouton Modifier séance (admin uniquement, géré en JS) -->
                  <a
                    href="/admin/showtimes/<%= st.id %>/edit"
                    class="btn btn-outline-secondary btn-sm mt-2 js-admin-only d-none"
                  >
                    Modifier la séance
                  </a>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>

      <div class="mt-4">
        <a href="/films-ejs" class="btn btn-secondary">
          ⬅ Retour aux films
        </a>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
      // Utilise getStoredUser() défini dans partials/navbar.ejs
      async function reserveShowtime(showtimeId, price) {
        const user =
          typeof getStoredUser === "function" ? getStoredUser() : null;

        if (!user || !user.username) {
          alert("Veuillez vous connecter pour réserver une séance.");
          window.location.href = "/";
          return;
        }

        const token =
          (user && (user.token || user.accessToken || user.jwt)) ||
          localStorage.getItem("token");

        if (!token) {
          alert("Veuillez vous reconnecter.");
          window.location.href = "/";
          return;
        }

        try {
          const res = await fetch("/api/bookings", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization: "Bearer " + token,
            },
            body: JSON.stringify({
              showtime_id: showtimeId,
              total_price: price,
            }),
          });

          const data = await res.json().catch(() => ({}));

          if (!res.ok) {
            alert(
              data.message ||
                data.error ||
                "Impossible de créer la réservation."
            );
            return;
          }

          alert("Réservation créée avec succès !");

          // Redirection vers Mes réservations avec username
          window.location.href =
            "/reservations-ejs?username=" +
            encodeURIComponent(user.username);
        } catch (err) {
          console.error("Erreur réservation :", err);
          alert("Erreur réseau lors de la réservation.");
        }
      }
    </script>
  </body>
</html>