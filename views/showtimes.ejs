<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Cinéma – Séances</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <%- include("partials/navbar") %>

    <main class="container py-5">
      <h1 class="mb-4 fw-bold">
        Séances pour <%= movie ? movie.title : "film inconnu" %>
      </h1>

      <% if (!movie) { %>
        <div class="alert alert-danger">
          Le film demandé n'existe pas.
        </div>
      <% } else if (!showtimes || showtimes.length === 0) { %>
        <div class="alert alert-info">
          Aucune séance programmée pour ce film.
        </div>
      <% } else { %>
        <div class="row g-4">
          <% showtimes.forEach(function(st) { %>
            <div class="col-md-6 col-lg-4">
              <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                  <h5 class="card-title">Séance</h5>

                  <p class="card-text flex-grow-1">
                    <strong>Date &amp; heure :</strong><br />
                    <%=
                      st.start_time
                        ? st.start_time.toLocaleString("fr-CA", {
                            weekday: "short",
                            year: "numeric",
                            month: "short",
                            day: "2-digit",
                            hour: "2-digit",
                            minute: "2-digit",
                          })
                        : "N/A"
                    %>
                    <br />
                    <strong>Salle :</strong>
                    <%= st.Room ? st.Room.name : "N/A" %><br />
                    <strong>Prix :</strong> <%= st.price %> $
                  </p>

                  <button
                    type="button"
                    class="btn btn-success mt-auto"
                    onclick="reserveShowtime(<%= st.id %>, <%= st.price %>)"
                  >
                    Réserver (démo)
                  </button>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>

      <div class="mt-4">
        <a href="/films-ejs" class="btn btn-secondary">
          ⬅ Retour aux films
        </a>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
      // Utilise getStoredUser() défini dans partials/navbar.ejs
      async function reserveShowtime(showtimeId, price) {
        const user = getStoredUser();

        if (!user || !user.token) {
          alert("Veuillez vous connecter pour voir vos réservations.");
          window.location.href = "/";
          return;
        }

        try {
          const res = await fetch("/api/bookings", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization: "Bearer " + user.token,
            },
            body: JSON.stringify({
              showtime_id: showtimeId,
              total_price: price,
            }),
          });

          const data = await res.json();

          if (!res.ok) {
            alert(data.message || "Impossible de créer la réservation.");
            return;
          }

          alert("Réservation créée avec succès !");
          const username = user.username || "";
          window.location.href =
            "/reservations-ejs?username=" + encodeURIComponent(username);
        } catch (err) {
          console.error(err);
          alert("Erreur réseau lors de la réservation.");
        }
      }
    </script>
  </body>
</html>