<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Cinéma – Mes réservations</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <%- include("partials/navbar") %>

    <main class="container py-5">
      <h1 class="mb-4 fw-bold">Mes réservations</h1>

      <% if (!user) { %>
        <div class="alert alert-warning">
          Aucun utilisateur n'est identifié.
        </div>
      <% } else { %>
        <p class="mb-4">
          Réservations pour :
          <strong><%= user.username %></strong>
          (ID : <%= user.id %>)
        </p>

        <% if (!bookings || bookings.length === 0) { %>
          <div class="alert alert-info">
            Aucune réservation trouvée pour cet utilisateur.
          </div>
        <% } else { %>
          <div class="row g-4">
            <% bookings.forEach(function (bk) { 
                 const showtime = bk.Showtime || bk.showtime || null;
                 const movie = showtime ? (showtime.Movie || showtime.movie || null) : null;
                 const room = showtime ? (showtime.Room || showtime.room || null) : null;
                 const startTime = showtime && showtime.start_time
                   ? new Date(showtime.start_time)
                   : null;
                 const bookingTime = bk.booking_time
                   ? new Date(bk.booking_time)
                   : null;
                 const status = (bk.status || "N/A").toString();
                 const statusLower = status.toLowerCase();
                 const isCancelled =
                   statusLower === "cancelled" ||
                   statusLower === "annulée" ||
                   statusLower === "annulee";
            %>
              <div class="col-md-6">
                <div class="card shadow-sm h-100">
                  <div class="card-body d-flex flex-column">
                    <h5 class="card-title">
                      <% if (movie && movie.title) { %>
                        <%= movie.title %>
                      <% } else { %>
                        Film inconnu
                      <% } %>
                    </h5>

                    <p class="card-text mb-2">
                      <strong>Date &amp; heure :</strong>
                      <% if (startTime) { %>
                        <%= startTime.toLocaleString("fr-CA", {
                              weekday: "short",
                              year: "numeric",
                              month: "short",
                              day: "2-digit",
                              hour: "2-digit",
                              minute: "2-digit",
                            }) %>
                      <% } else { %>
                        N/A
                      <% } %>
                      <br />
                      <strong>Salle :</strong>
                      <% if (room && room.name) { %>
                        <%= room.name %>
                      <% } else { %>
                        N/A
                      <% } %>
                      <br />
                      <strong>Statut :</strong>
                      <%= status %>
                      <br />
                      <strong>Réservé le :</strong>
                      <% if (bookingTime) { %>
                        <%= bookingTime.toLocaleString("fr-CA") %>
                      <% } else { %>
                        N/A
                      <% } %>
                    </p>

                    <% if (!isCancelled) { %>
                      <button
                        type="button"
                        class="btn btn-outline-danger btn-sm mt-auto"
                        onclick="cancelBooking(<%= bk.id %>)"
                      >
                        Annuler la réservation
                      </button>
                    <% } else { %>
                      <p class="text-danger small mt-auto mb-0">
                        Réservation annulée.
                      </p>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      <% } %>

      <div class="mt-4">
        <a href="/films-ejs" class="btn btn-secondary">
          ⬅ Retour aux films
        </a>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
      // Annuler une réservation
      async function cancelBooking(bookingId) {
        if (!confirm("Voulez-vous vraiment annuler cette réservation ?")) {
          return;
        }

        const user =
          typeof getStoredUser === "function" ? getStoredUser() : null;

        const token =
          (user && (user.token || user.accessToken || user.jwt)) ||
          localStorage.getItem("token");

        if (!token) {
          alert("Veuillez vous reconnecter.");
          window.location.href = "/";
          return;
        }

        try {
          const res = await fetch("/api/bookings/" + bookingId, {
            method: "DELETE",
            headers: {
              "Content-Type": "application/json",
              Authorization: "Bearer " + token,
            },
          });

          const data = await res.json().catch(() => ({}));

          if (!res.ok) {
            alert(
              data.message ||
                data.error ||
                "Impossible d'annuler la réservation."
            );
            return;
          }

          alert("Réservation annulée.");
          window.location.reload();
        } catch (err) {
          console.error("Erreur lors de l'annulation :", err);
          alert("Erreur réseau lors de l'annulation.");
        }
      }
    </script>
  </body>
</html>