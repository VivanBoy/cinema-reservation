<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Cinéma – Mes réservations</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <%- include("partials/navbar") %>

    <main class="container py-5">
      <h1 class="mb-4 fw-bold">Mes réservations</h1>

      <% if (!user) { %>
        <div class="alert alert-warning">
          Aucun utilisateur n'est identifié.
        </div>
      <% } else { %>
        <p class="mb-4">
          Réservations pour :
          <strong><%= user.username %></strong>
          (ID: <%= user.id %>)
        </p>

        <% if (!bookings || bookings.length === 0) { %>
          <div class="alert alert-info">
            Aucune réservation trouvée pour cet utilisateur.
          </div>
        <% } else { %>
          <div class="row g-4">
            <% bookings.forEach(function(bk) { %>
              <div class="col-md-6">
                <div class="card shadow-sm h-100">
                  <div class="card-body">
                    <h5 class="card-title">
                      <%= bk.Showtime && bk.Showtime.Movie
                        ? bk.Showtime.Movie.title
                        : "Film inconnu"
                      %>
                    </h5>

                    <p class="card-text">
                      <strong>Date &amp; heure :</strong>
                      <%=
                        bk.Showtime && bk.Showtime.start_time
                          ? bk.Showtime.start_time.toLocaleString("fr-CA", {
                              weekday: "short",
                              year: "numeric",
                              month: "short",
                              day: "2-digit",
                              hour: "2-digit",
                              minute: "2-digit",
                            })
                          : "N/A"
                      %>
                      <br />
                      <strong>Salle :</strong>
                      <%= bk.Showtime && bk.Showtime.Room
                        ? bk.Showtime.Room.name
                        : "N/A"
                      %><br />
                      <strong>Statut :</strong> <%= bk.status %><br />
                      <strong>Réservé le :</strong>
                      <%=
                        bk.booking_time
                          ? bk.booking_time.toLocaleString("fr-CA")
                          : "N/A"
                      %>
                    </p>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      <% } %>

      <div class="mt-4">
        <a href="/films-ejs" class="btn btn-secondary">
          ⬅ Retour aux films
        </a>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>