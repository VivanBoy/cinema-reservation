<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Cinéma – Mes réservations</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <%- include("partials/navbar") %>

    <main class="container py-5">
      <h1 class="mb-4 fw-bold">Mes réservations</h1>

      <% if (!user) { %>
        <div class="alert alert-warning">
          Aucun utilisateur n'est identifié.
        </div>
      <% } else { %>
        <p class="mb-4">
          Réservations pour :
          <strong><%= user.username %></strong>
          (ID : <%= user.id %>)
        </p>

        <% if (!bookings || bookings.length === 0) { %>
          <div class="alert alert-info">
            Aucune réservation trouvée pour cet utilisateur.
          </div>
        <% } else { %>
          <div class="row g-4">
            <% bookings.forEach(function (bk) { 
                 const showtime = bk.Showtime || bk.showtime || null;
                 const movie = showtime ? (showtime.Movie || showtime.movie || null) : null;
                 const room = showtime ? (showtime.Room || showtime.room || null) : null;
                 const startTime = showtime && showtime.start_time
                   ? new Date(showtime.start_time)
                   : null;
                 const bookingTime = bk.booking_time
                   ? new Date(bk.booking_time)
                   : null;
            %>
              <div class="col-md-6">
                <div class="card shadow-sm h-100">
                  <div class="card-body d-flex flex-column">
                    <h5 class="card-title">
                      <% if (movie && movie.title) { %>
                        <%= movie.title %>
                      <% } else { %>
                        Film inconnu
                      <% } %>
                    </h5>

                    <p class="card-text mb-2">
                      <strong>Date &amp; heure :</strong>
                      <% if (startTime) { %>
                        <%= startTime.toLocaleString("fr-CA", {
                              weekday: "short",
                              year: "numeric",
                              month: "short",
                              day: "2-digit",
                              hour: "2-digit",
                              minute: "2-digit",
                            }) %>
                      <% } else { %>
                        N/A
                      <% } %>
                      <br />
                      <strong>Salle :</strong>
                      <% if (room && room.name) { %>
                        <%= room.name %>
                      <% } else { %>
                        N/A
                      <% } %>
                      <br />
                      <strong>Statut :</strong>
                      <%= bk.status || "N/A" %>
                      <br />
                      <strong>Réservé le :</strong>
                      <% if (bookingTime) { %>
                        <%= bookingTime.toLocaleString("fr-CA") %>
                      <% } else { %>
                        N/A
                      <% } %>
                    </p>

                    <p class="small text-muted mt-auto mb-0">
                      Code QR de la réservation :
                      <em>(non implémenté dans cette version)</em>
                    </p>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      <% } %>

      <div class="mt-4">
        <a href="/films-ejs" class="btn btn-secondary">
          ⬅ Retour aux films
        </a>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
