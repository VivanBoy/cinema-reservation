<!-- views/admin-new-movie.ejs -->
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Admin – Ajouter un film</title>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
  />
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark mb-4">
    <div class="container">
      <a class="navbar-brand" href="/films-ejs">🎬 Cinéma – Réservation</a>
      <span class="navbar-text text-white">Admin – Nouveau film</span>
    </div>
  </nav>

  <div class="container">
    <h1 class="mb-4">Ajouter un film</h1>

    <form method="POST" action="/admin/movies" class="row g-3">

      <div class="col-md-6">
        <label class="form-label">Titre</label>
        <input
          type="text"
          name="title"
          class="form-control"
          required
        />
      </div>

      <div class="col-md-6">
        <label class="form-label">Classification (rating)</label>
        <input
          type="text"
          name="rating"
          class="form-control"
          placeholder="PG-13, G, etc."
        />
      </div>

      <div class="col-12">
        <label class="form-label">Description</label>
        <textarea
          name="description"
          rows="3"
          class="form-control"
        ></textarea>
      </div>

      <!-- 🆕 URL ou chemin de l'affiche -->
      <div class="col-md-6">
        <label class="form-label">Affiche (URL ou /img/fichier.jpg)</label>
        <input
          type="text"
          name="poster_url"
          class="form-control"
          placeholder="https://... ou /img/inception.jpg"
        />
      </div>

      <div class="col-md-3">
        <label class="form-label">Durée (minutes)</label>
        <input
          type="number"
          min="1"
          name="duration_minutes"
          class="form-control"
        />
      </div>

      <div class="col-md-3">
        <label class="form-label">Date de sortie</label>
        <input
          type="date"
          name="release_date"
          class="form-control"
        />
      </div>

      <div class="col-12 mt-3">
        <button type="submit" class="btn btn-success">
          Ajouter le film
        </button>
        <a href="/films-ejs" class="btn btn-secondary ms-2">
          Annuler
        </a>
      </div>
    </form>
  </div>
</body>