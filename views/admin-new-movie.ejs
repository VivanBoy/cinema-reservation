<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Cinéma – Admin | Nouveau film</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <%- include("partials/navbar", { activePage: "admin-movies" }) %>

    <main class="container py-5">
      <h1 class="mb-4 fw-bold">Ajouter un film</h1>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="alert alert-danger">
          <%= error %>
        </div>
      <% } %>

      <form method="post" action="/admin/movies" class="row g-3">
        <div class="col-md-6">
          <label for="title" class="form-label">Titre *</label>
          <input
            type="text"
            id="title"
            name="title"
            class="form-control"
            required
            minlength="2"
            value="<%= (old && old.title) || '' %>"
          />
        </div>

        <div class="col-md-6">
          <label for="rating" class="form-label">Classification (rating)</label>
          <input
            type="text"
            id="rating"
            name="rating"
            class="form-control"
            placeholder="PG-13, G, etc."
            maxlength="10"
            value="<%= (old && old.rating) || '' %>"
          />
        </div>

        <div class="col-12">
          <label for="description" class="form-label">Description</label>
          <textarea
            id="description"
            name="description"
            class="form-control"
            rows="4"
          ><%= (old && old.description) || '' %></textarea>
        </div>

        <div class="col-md-4">
          <label for="duration_minutes" class="form-label">
            Durée (minutes)
          </label>
          <input
            type="number"
            id="duration_minutes"
            name="duration_minutes"
            class="form-control"
            min="1"
            value="<%= (old && old.duration_minutes) || '' %>"
          />
        </div>

        <div class="col-md-4">
          <label for="release_date" class="form-label">Date de sortie</label>
          <input
            type="date"
            id="release_date"
            name="release_date"
            class="form-control"
            value="<%= (old && old.release_date) || '' %>"
          />
        </div>

        <div class="col-md-4">
          <label for="poster_url" class="form-label">URL de l'affiche</label>
          <input
            type="url"
            id="poster_url"
            name="poster_url"
            class="form-control"
            placeholder="https://exemple.com/affiche.jpg"
            value="<%= (old && old.poster_url) || '' %>"
          />
        </div>

        <div class="col-12 mt-3">
          <button type="submit" class="btn btn-primary">
            Enregistrer le film
          </button>
          <a href="/films-ejs" class="btn btn-secondary ms-2">
            Annuler
          </a>
        </div>
      </form>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
