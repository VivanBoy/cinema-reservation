<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Cinéma – Réservation | Détails du film</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container-fluid">
        <a class="navbar-brand fw-semibold" href="/films-ejs">
          🎬 Cinéma – Réservation
        </a>

        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#mainNavbar"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link" href="/films-ejs">Films</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" id="reservationsLink" href="/reservations-ejs">
                Mes réservations
              </a>
            </li>
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle"
                href="#"
                role="button"
                data-bs-toggle="dropdown"
              >
                Admin
              </a>
              <ul class="dropdown-menu">
                <li>
                  <a class="dropdown-item" href="/admin/movies/new">
                    Ajouter un film
                  </a>
                </li>
                <li>
                  <a class="dropdown-item" href="/admin/showtimes/new">
                    Ajouter une séance
                  </a>
                </li>
              </ul>
            </li>
          </ul>

          <div class="d-flex align-items-center gap-2">
            <span id="navbarUser" class="navbar-text text-white small"></span>
            <button
              type="button"
              class="btn btn-outline-light btn-sm"
              onclick="logout()"
            >
              Se déconnecter
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- CONTENU -->
    <main class="container py-5">
      <% if (!movie) { %>
      <div class="alert alert-danger">
        Le film demandé n'existe pas.
      </div>

      <a href="/films-ejs" class="btn btn-secondary">
        ⬅ Retour aux films
      </a>
      <% } else { %>

      <div class="row g-5 align-items-start">
        <!-- Affiche -->
        <div class="col-md-5">
          <% if (movie.poster_url) { %>
          <img
            src="<%= movie.poster_url %>"
            alt="Affiche de <%= movie.title %>"
            class="img-fluid rounded shadow-sm"
          />
          <% } else { %>
          <div
            class="bg-secondary-subtle border rounded p-4 text-center text-muted"
          >
            Aucune image disponible pour ce film.
          </div>
          <% } %>
        </div>

        <!-- Infos film -->
        <div class="col-md-7">
          <h1 class="mb-4 fw-bold"><%= movie.title %></h1>

          <h4 class="fw-semibold mb-3">Description :</h4>
          <p class="fs-5">
            <%= movie.description || "Aucune description disponible." %>
          </p>

          <p class="fs-5 mb-1">
            <strong>Durée :</strong>
            <%= movie.duration_minutes || "N/A" %> minutes
          </p>
          <p class="fs-5 mb-1">
            <strong>Classification :</strong>
            <%= movie.rating || "N/A" %>
          </p>
          <p class="fs-5 mb-4">
            <strong>Date de sortie :</strong>
            <% if (movie.release_date) { %>
              <%= new Date(movie.release_date).toISOString().slice(0, 10) %>
            <% } else { %>
              Non renseignée
            <% } %>
          </p>

          <div class="d-flex flex-wrap gap-3">
            <!-- NOUVEAU : bouton Voir les séances -->
            <a
              href="/films-ejs/<%= movie.id %>/showtimes"
              class="btn btn-success"
            >
              Voir les séances
            </a>

            <!-- Bouton retour -->
            <a href="/films-ejs" class="btn btn-secondary">
              ⬅ Retour aux films
            </a>
          </div>
        </div>
      </div>
      <% } %>
    </main>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      (function initNavbarUser() {
        const span = document.getElementById("navbarUser");
        const username = localStorage.getItem("username");
        if (span && username) {
          span.textContent = "Connecté : " + username;
        }
      })();

      (function updateReservationsLink() {
        const link = document.getElementById("reservationsLink");
        const userId = localStorage.getItem("userId");
        if (link && userId) {
          link.href = "/reservations-ejs?userId=" + encodeURIComponent(userId);
        }
      })();

      function logout() {
        localStorage.removeItem("token");
        localStorage.removeItem("username");
        localStorage.removeItem("userId");
        window.location.href = "/";
      }
    </script>
  </body>
</html>