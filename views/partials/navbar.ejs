      <div class="d-flex align-items-center gap-2">
        <span id="navbarUser" class="navbar-text text-white small"></span>
        <button
          type="button"
          class="btn btn-outline-light btn-sm"
          onclick="logout()"
        >
          Se déconnecter
        </button>
      </div>
    </div>
