<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container-fluid">
    <a class="navbar-brand fw-semibold" href="/films-ejs">
      🎬 Cinéma – Réservation
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mainNavbar"
      aria-controls="mainNavbar"
      aria-expanded="false"
      aria-label="Basculer la navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNavbar">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a
            class="nav-link <%= activePage === 'films' ? 'active' : '' %>"
            href="/films-ejs"
          >
            Films
          </a>
        </li>

        <li class="nav-item">
          <a
            id="reservationsLink"
            class="nav-link <%= activePage === 'reservations' ? 'active' : '' %>"
            href="/reservations-ejs"
          >
            Mes réservations
          </a>
        </li>

        <!-- Menu Admin (caché par défaut, visible uniquement si admin en JS) -->
        <li class="nav-item dropdown d-none" id="adminMenu">
          <a
            class="nav-link dropdown-toggle"
            href="#"
            role="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
          >
            Admin
          </a>
          <ul class="dropdown-menu">
            <li>
              <a class="dropdown-item" href="/admin/movies/new">
                Ajouter un film
              </a>
            </li>
            <li>
              <a class="dropdown-item" href="/admin/showtimes/new">
                Ajouter une séance
              </a>
            </li>
          </ul>
        </li>
      </ul>

      <div class="d-flex align-items-center gap-2">
        <span id="navbarUser" class="navbar-text text-white small"></span>

        <!-- Bouton Connexion / Inscription (si pas connecté) -->
        <a
          id="loginBtn"
          href="/"
          class="btn btn-outline-light btn-sm d-none"
        >
          Connexion / Inscription
        </a>

        <!-- Bouton Déconnexion (si connecté) -->
        <button
          id="logoutBtn"
          type="button"
          class="btn btn-outline-light btn-sm d-none"
        >
          Se déconnecter
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  (function () {
    // Lecture robuste du user dans le localStorage
    function getStoredUser() {
      // Format principal : "cinemaUser" en JSON
      try {
        const raw = localStorage.getItem("cinemaUser");
        if (raw) {
          const obj = JSON.parse(raw);
          if (obj && (obj.username || obj.id || obj.userId)) {
            return obj;
          }
        }
      } catch (e) {
        console.warn("Impossible de parser cinemaUser :", e);
      }

      // Ancien format de secours : username / userId / token
      const backupUsername = localStorage.getItem("username");
      const backupId = localStorage.getItem("userId");
      const backupToken = localStorage.getItem("token");

      if (backupUsername || backupId || backupToken) {
        return {
          username: backupUsername || null,
          id: backupId ? parseInt(backupId, 10) : null,
          roles: [],
          token: backupToken || null,
        };
      }

      return null;
    }

    function updateNavbar() {
      const user = getStoredUser();

      const spanUser = document.getElementById("navbarUser");
      const reservationsLink = document.getElementById("reservationsLink");
      const adminMenu = document.getElementById("adminMenu");
      const loginBtn = document.getElementById("loginBtn");
      const logoutBtn = document.getElementById("logoutBtn");

      // Par défaut
      if (spanUser) spanUser.textContent = "";
      if (adminMenu) adminMenu.classList.add("d-none");

      // Pas connecté
      if (!user) {
        if (reservationsLink) {
          // Lien générique → affichera la page d’explication "reservations-no-user"
          reservationsLink.href = "/reservations-ejs";
        }
        if (loginBtn) loginBtn.classList.remove("d-none");
        if (logoutBtn) logoutBtn.classList.add("d-none");
        return;
      }

      // Connecté
      if (spanUser && user.username) {
        spanUser.textContent = "Connecté : " + user.username;
      }

      // Lien "Mes réservations" avec userId quand il est disponible
      if (reservationsLink && user.id != null) {
        reservationsLink.href =
          "/reservations-ejs?userId=" + encodeURIComponent(user.id);
      }

      // Affichage du menu Admin si rôle admin
      const roles = user.roles || [];
      const isAdmin =
        roles.includes("admin") ||
        roles.includes("ROLE_ADMIN");

      if (adminMenu) {
        if (isAdmin) adminMenu.classList.remove("d-none");
        else adminMenu.classList.add("d-none");
      }

      // Boutons login / logout
      if (loginBtn) loginBtn.classList.add("d-none");
      if (logoutBtn) logoutBtn.classList.remove("d-none");
    }

    // Fonction logout globale
    window.logout = function () {
      localStorage.removeItem("cinemaUser");
      localStorage.removeItem("token");
      localStorage.removeItem("username");
      localStorage.removeItem("userId");
      window.location.href = "/";
    };

    document.addEventListener("DOMContentLoaded", updateNavbar);
  })();
</script>
